# ─── NVIDIA NIM API ───────────────────────────────────────────────────────────
# Obtain from https://integrate.api.nvidia.com
NVIDIA_API_KEY=nvapi-your-key-here

# Embedding model (NeMo Retriever) — output dim: 1024
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# LLM for answer generation
NVIDIA_LLM_MODEL=meta/llama-3.3-70b-instruct

# Base URL for all NVIDIA NIM API calls
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# ─── Vector DB (ChromaDB — file-based, no Docker needed) ─────────────────────
CHROMA_PATH=./chroma_db
CHROMA_COLLECTION=civic_ai_docs

# ─── Document Storage ─────────────────────────────────────────────────────────
DOCS_FOLDER=./docs

# ─── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ─── JWT Authentication ───────────────────────────────────────────────────────
JWT_SECRET_KEY=replace-with-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ─── WhatsApp / Meta Cloud API ────────────────────────────────────────────────
# Webhook verify token — any string you choose in the Meta developer console
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# Permanent or temporary access token from Meta Business Suite
WHATSAPP_ACCESS_TOKEN=your-meta-access-token-here
# Phone Number ID from Meta developer console → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# ─── Web Scraping ─────────────────────────────────────────────────────────────
# How often (in hours) to scrape BBMP + BenSCL and push WhatsApp notifications
SCRAPE_INTERVAL_HOURS=2

# ─── Tavily Search API (web augmentation for RAG answers) ────────────────────
TAVILY_API_KEY=tvly-your-key-here
